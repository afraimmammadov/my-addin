<!DOCTYPE html>
<html lang="az">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Qonaq Buraxılışı — Forma 1</title>
  <script src="https://appsforoffice.microsoft.com/lib/1.1/hosted/office.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/docx/8.5.0/docx.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
  <style>
    :root {
      --dark: #1a1a2e;
      --accent: #0078d4;
      --accent-h: #106ebe;
      --ok: #107c10;
      --bg: #f4f5f7;
      --card: #ffffff;
      --bdr: #e1e4e8;
      --txt: #24292e;
      --txt2: #586069;
      --err: #d13438;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:'Segoe UI',system-ui,sans-serif; font-size:13px; color:var(--txt); background:var(--bg); }

    /* Header */
    .hdr { background:var(--dark); color:#fff; padding:13px 16px; display:flex; align-items:center; gap:10px; }
    .hdr-icon { width:28px; height:28px; background:var(--accent); border-radius:6px; display:flex; align-items:center; justify-content:center; font-size:14px; }
    .hdr h1 { font-size:13.5px; font-weight:700; }
    .hdr p { font-size:10.5px; opacity:.6; margin-top:1px; }

    /* Meeting bar */
    .mbar { background:var(--card); border-bottom:1px solid var(--bdr); padding:9px 16px; display:flex; gap:16px; font-size:11.5px; }
    .mbar .lbl { font-size:9.5px; text-transform:uppercase; letter-spacing:.7px; color:var(--txt2); font-weight:700; }
    .mbar b { display:block; margin-top:1px; }

    /* Content */
    .wrap { padding:14px 16px; }

    /* Section title */
    .stitle { font-size:11.5px; font-weight:700; color:var(--dark); margin-bottom:10px; padding-bottom:5px; border-bottom:2px solid var(--accent); display:inline-block; }

    /* Attendee row */
    .att-row { display:flex; align-items:center; gap:8px; padding:7px 10px; margin-bottom:3px; background:var(--card); border:1px solid var(--bdr); border-radius:6px; cursor:pointer; transition:all .15s; }
    .att-row.sel { background:rgba(0,120,212,.05); border-color:rgba(0,120,212,.3); }
    .att-row input[type=checkbox] { accent-color:var(--accent); width:15px; height:15px; }
    .att-name { font-size:12.5px; font-weight:600; }
    .att-email { font-size:10px; color:var(--txt2); }
    .att-badge { display:inline-block; background:rgba(0,120,212,.1); color:var(--accent); font-size:9.5px; font-weight:700; padding:2px 7px; border-radius:10px; margin-left:auto; }

    /* Guest detail card */
    .gcard { background:var(--card); border:1px solid var(--bdr); border-radius:8px; padding:11px 11px 7px; margin-bottom:7px; position:relative; }
    .gcard-num { position:absolute; top:-7px; left:10px; background:var(--accent); color:#fff; font-size:9.5px; font-weight:700; width:17px; height:17px; border-radius:50%; display:flex; align-items:center; justify-content:center; }
    .gcard-name { font-size:12px; font-weight:600; margin-bottom:7px; padding-left:18px; }
    .gcard .row { display:flex; gap:7px; margin-bottom:5px; }

    /* Fields */
    .fg { flex:1; display:flex; flex-direction:column; gap:2px; }
    .fg label { font-size:10px; font-weight:600; color:var(--txt2); }
    .fg input, .fg select, .fg textarea {
      border:1px solid var(--bdr); border-radius:5px; padding:6px 8px; font-size:12px;
      font-family:inherit; color:var(--txt); background:#fafbfc; outline:none; width:100%;
    }
    .fg input:focus, .fg select:focus, .fg textarea:focus {
      border-color:var(--accent); box-shadow:0 0 0 2px rgba(0,120,212,.1); background:#fff;
    }
    .fg textarea { resize:vertical; min-height:40px; }

    /* Meta form card */
    .meta-card { margin-top:10px; background:var(--card); border:1px solid var(--bdr); border-radius:8px; padding:11px; }

    /* Buttons */
    .btn { padding:9px 16px; border-radius:6px; font-size:12.5px; font-weight:600; cursor:pointer; border:none; transition:all .15s; }
    .btn-p { background:var(--accent); color:#fff; }
    .btn-p:hover { background:var(--accent-h); }
    .btn-p:disabled { background:#c8c6c4; cursor:not-allowed; }
    .btn-g { background:transparent; border:1px solid var(--bdr); color:var(--txt); }
    .btn-g:hover { background:#f0f2f5; }
    .btn-full { flex:1; }
    .btn-row { display:flex; gap:8px; margin-top:12px; }

    /* Preview */
    .preview-box { background:#fff; border:1px solid var(--bdr); border-radius:6px; padding:12px; margin-bottom:9px; font-size:11px; line-height:1.6; }
    .preview-box table { width:100%; border-collapse:collapse; font-size:10px; }
    .preview-box th { padding:4px 6px; border-bottom:1px solid var(--bdr); text-align:left; font-weight:600; background:#f0f2f5; }
    .preview-box td { padding:3px 6px; border-bottom:1px solid #f0f2f5; }
    .preview-box .info-row td { padding:3px 8px; border-bottom:1px solid var(--bdr); }
    .preview-box .info-row td:first-child { font-weight:600; color:var(--txt2); width:80px; }

    .email-box { background:#fafbfc; border:1px solid var(--bdr); border-radius:6px; padding:11px; margin-bottom:9px; font-size:11px; }
    .email-body { white-space:pre-wrap; background:#fff; padding:8px; border-radius:4px; border:1px solid var(--bdr); margin-top:6px; line-height:1.6; }

    /* Center state */
    .center { text-align:center; padding:28px 10px; }
    .center .icon { font-size:34px; margin-bottom:10px; }
    .center h2 { font-size:14px; font-weight:600; margin-bottom:5px; }
    .center p { font-size:12px; color:var(--txt2); line-height:1.5; margin-bottom:16px; }

    /* Status */
    .status { padding:9px 14px; border-radius:6px; font-size:12px; font-weight:500; text-align:center; margin-top:8px; }
    .status.ok { background:#dff6dd; color:var(--ok); border:1px solid #a7e3a5; }
    .status.err { background:#fde7e9; color:var(--err); border:1px solid #f1bbbc; }

    /* Loading spinner */
    .spinner { display:inline-block; width:14px; height:14px; border:2px solid rgba(255,255,255,.3); border-top-color:#fff; border-radius:50%; animation:spin .5s linear infinite; vertical-align:middle; margin-right:6px; }
    @keyframes spin { to { transform:rotate(360deg); } }

    .hidden { display:none !important; }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="hdr">
    <div class="hdr-icon">🏢</div>
    <div>
      <h1>Qonaq Buraxılışı</h1>
      <p>Forma 1 — SOCAR Tower</p>
    </div>
  </div>

  <!-- Meeting info bar -->
  <div class="mbar">
    <div><span class="lbl">Görüş</span><b id="mSubject">—</b></div>
    <div><span class="lbl">Tarix</span><b id="mDate">—</b></div>
  </div>

  <div class="wrap">
    <!-- ═══ STEP 0: Prompt ═══ -->
    <div id="step0" class="center">
      <div class="icon">📋</div>
      <h2>Buraxılış forması lazımdır?</h2>
      <p id="step0desc">Attendee-lər üçün Forma 1 hazırlanacaq<br>və reception-a göndəriləcək</p>
      <div style="display:flex;gap:8px;justify-content:center;">
        <button class="btn btn-p" onclick="startProcess()">Bəli, hazırla</button>
        <button class="btn btn-g" onclick="window.close()">Xeyr</button>
      </div>
    </div>

    <!-- ═══ STEP 1: Select attendees ═══ -->
    <div id="step1" class="hidden">
      <div class="stitle" id="attTitle">Attendee-ləri seç</div>
      <div id="attList"></div>
      <div class="btn-row">
        <button class="btn btn-p btn-full" id="btnToStep2" onclick="goStep2()">Davam et — Detalları doldur</button>
      </div>
    </div>

    <!-- ═══ STEP 2: Fill details ═══ -->
    <div id="step2" class="hidden">
      <div class="stitle">Qonaq detalları</div>
      <div id="guestDetails"></div>

      <div class="meta-card">
        <div class="stitle">Forma məlumatları</div>
        <div class="row" style="display:flex;gap:7px;margin-bottom:5px;">
          <div class="fg"><label>Dəvətin məqsədi</label><input id="fPurpose" value="Layihə ilə əlaqədar" /></div>
        </div>
        <div class="row" style="display:flex;gap:7px;margin-bottom:5px;">
          <div class="fg"><label>Dəvət olunduğu yer</label><input id="fLocation" value="SOCAR Tower /25-ci mərtəbə" /></div>
          <div class="fg"><label>Müddət</label><input id="fPeriod" value="" /></div>
        </div>
        <div class="row" style="display:flex;gap:7px;margin-bottom:5px;">
          <div class="fg"><label>Bölmə / Departament</label><input id="fDept" value="" /></div>
          <div class="fg"><label>Əlaqəli şəxs</label><input id="fContact" value="" /></div>
        </div>
        <div class="row" style="display:flex;gap:7px;margin-bottom:5px;">
          <div class="fg"><label>Daxili nömrə</label><input id="fExt" value="" /></div>
        </div>
        <div class="row" style="display:flex;gap:7px;">
          <div class="fg"><label>Təsdiq edən (ad)</label><input id="fApprName" value="" /></div>
          <div class="fg"><label>Vəzifə</label><input id="fApprTitle" value="" /></div>
        </div>
      </div>

      <div class="btn-row">
        <button class="btn btn-g" onclick="goStep1()">← Geri</button>
        <button class="btn btn-p btn-full" onclick="goStep3()">Önizləmə →</button>
      </div>
    </div>

    <!-- ═══ STEP 3: Preview & Send ═══ -->
    <div id="step3" class="hidden">
      <div class="stitle">Önizləmə</div>

      <div class="preview-box" id="previewForma"></div>

      <div class="email-box">
        <div style="font-size:10px;color:var(--txt2);font-weight:600;margin-bottom:4px;">EMAIL GÖNDƏRİLƏCƏK:</div>
        <div id="emailMeta"></div>
        <div class="email-body" id="emailBody"></div>
      </div>

      <div class="fg" style="margin-bottom:4px;">
        <label>Reception email</label>
        <input id="fRecipient" value="socar.reception@socar.az" />
      </div>

      <div class="btn-row">
        <button class="btn btn-g" onclick="goStep2From3()">← Düzəliş</button>
        <button class="btn btn-p btn-full" id="btnSend" onclick="sendAll()">📧 Göndər + 📎 Forma 1</button>
      </div>
      <div id="statusBar" class="status hidden"></div>
    </div>

    <!-- ═══ STEP 4: Done ═══ -->
    <div id="step4" class="hidden center">
      <div class="icon">✅</div>
      <h2 style="color:var(--ok);">Göndərildi!</h2>
      <p id="doneMsg"></p>
      <button class="btn btn-g" onclick="resetAll()">Yeni sifariş</button>
    </div>
  </div>

<script>
// ═══════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════
let attendees = [];
let selectedIds = new Set();
let meetingData = { subject: '', dateTime: '', organizer: '', department: '', ext: '' };

const SUBSIDIARIES = [
  "SOCAR-ın Baş ofisi","Azneft","Azəriqaz","Azərikimya","SDM","CIC",
  "NeftQazTikinti","SOCAR Upstream","SOCAR Midstream","Qaz İxrac İdarəsi",
  "Kompleks Qazma","Neft Kəmərləri","SOCAR Polymer","SOCAR Methanol",
  "SOCAR Energy","PwC","Digər"
];

// ═══════════════════════════════════════════════════
// OFFICE.JS INITIALIZATION
// ═══════════════════════════════════════════════════
Office.onReady(function(info) {
  if (info.host === Office.HostType.Outlook) {
    loadFromOutlook();
  } else {
    // Fallback for testing outside Outlook
    meetingData = {
      subject: 'SAP SF UAT müzakirəsi',
      dateTime: formatDate(new Date()),
      organizer: 'Test İstifadəçi',
      department: 'Test Departament',
      ext: '00000'
    };
    updateMeetingBar();
    document.getElementById('fDept').value = meetingData.department;
    document.getElementById('fContact').value = meetingData.organizer;
    document.getElementById('fExt').value = meetingData.ext;
  }
});

function loadFromOutlook() {
  const item = Office.context.mailbox.item;

  // Subject
  item.subject.getAsync(function(r) {
    if (r.status === Office.AsyncResultStatus.Succeeded) {
      meetingData.subject = r.value || 'Görüş';
      updateMeetingBar();
    }
  });

  // Start time
  item.start.getAsync(function(r) {
    if (r.status === Office.AsyncResultStatus.Succeeded) {
      meetingData.dateTime = formatDate(r.value);
      updateMeetingBar();
    }
  });

  // Organizer info from user profile
  try {
    const profile = Office.context.mailbox.userProfile;
    meetingData.organizer = profile.displayName || '';
    meetingData.department = ''; // Will need Graph API for department
    document.getElementById('fContact').value = meetingData.organizer;
  } catch(e) {}

  // Required attendees
  item.requiredAttendees.getAsync(function(r) {
    if (r.status === Office.AsyncResultStatus.Succeeded) {
      const required = (r.value || []).map((a, i) => ({
        id: i,
        name: a.displayName || a.emailAddress,
        email: a.emailAddress,
        company: guessCompany(a.emailAddress),
        vehicle: '',
        type: 'required'
      }));

      // Optional attendees
      item.optionalAttendees.getAsync(function(r2) {
        let optional = [];
        if (r2.status === Office.AsyncResultStatus.Succeeded) {
          optional = (r2.value || []).map((a, i) => ({
            id: required.length + i,
            name: a.displayName || a.emailAddress,
            email: a.emailAddress,
            company: guessCompany(a.emailAddress),
            vehicle: '',
            type: 'optional'
          }));
        }
        attendees = [...required, ...optional];
        document.getElementById('step0desc').innerHTML =
          attendees.length + ' attendee üçün Forma 1 hazırlanacaq<br>və reception-a göndəriləcək';
      });
    }
  });
}

function guessCompany(email) {
  if (!email) return '';
  email = email.toLowerCase();
  if (email.includes('pwc')) return 'PwC';
  if (email.includes('cic.socar') || email.includes('@cic.')) return 'CIC';
  if (email.includes('azeriqaz') || email.includes('azəriqaz')) return 'Azəriqaz';
  if (email.includes('gei.socar') || email.includes('qaz')) return 'Qaz İxrac İdarəsi';
  if (email.includes('azneft')) return 'Azneft';
  if (email.includes('sdm')) return 'SDM';
  if (email.includes('upstream')) return 'SOCAR Upstream';
  if (email.includes('midstream')) return 'SOCAR Midstream';
  if (email.includes('azerikimya') || email.includes('azərikimya')) return 'Azərikimya';
  if (email.includes('neftqaz')) return 'NeftQazTikinti';
  if (email.includes('polymer')) return 'SOCAR Polymer';
  if (email.includes('socar.az')) return 'SOCAR-ın Baş ofisi';
  return '';
}

function formatDate(d) {
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  const yy = d.getFullYear();
  const hh = String(d.getHours()).padStart(2,'0');
  const mi = String(d.getMinutes()).padStart(2,'0');
  return dd+'.'+mm+'.'+yy+', '+hh+':'+mi;
}

function updateMeetingBar() {
  document.getElementById('mSubject').textContent = meetingData.subject;
  document.getElementById('mDate').textContent = meetingData.dateTime;
}

// ═══════════════════════════════════════════════════
// STEP NAVIGATION
// ═══════════════════════════════════════════════════
function showStep(n) {
  ['step0','step1','step2','step3','step4'].forEach(id => {
    document.getElementById(id).classList.add('hidden');
  });
  document.getElementById('step'+n).classList.remove('hidden');
}

function startProcess() {
  // If no attendees from Outlook, allow manual entry
  if (attendees.length === 0) {
    attendees = [{ id: 0, name: '', email: '', company: '', vehicle: '', type: 'manual' }];
  }
  selectedIds = new Set(attendees.map(a => a.id));
  renderAttendeeList();
  showStep(1);
}

function goStep1() { showStep(1); }

function goStep2() {
  if (selectedIds.size === 0) return;
  renderGuestDetails();
  showStep(2);
}

function goStep2From3() { showStep(2); }

function goStep3() {
  renderPreview();
  showStep(3);
}

// ═══════════════════════════════════════════════════
// STEP 1: ATTENDEE LIST
// ═══════════════════════════════════════════════════
function renderAttendeeList() {
  const list = document.getElementById('attList');
  const hasManual = attendees.some(a => a.type === 'manual');

  let html = '';
  attendees.forEach(a => {
    const sel = selectedIds.has(a.id);
    if (a.type === 'manual') {
      // Manual entry row
      html += `
        <div class="gcard" style="margin-bottom:6px;">
          <div class="row" style="display:flex;gap:7px;">
            <div class="fg"><label>Ad Soyad</label><input id="manName${a.id}" value="${esc(a.name)}" placeholder="Qonağın adı soyadı" onchange="attendees[${a.id}].name=this.value" /></div>
            <div class="fg"><label>Email</label><input id="manEmail${a.id}" value="${esc(a.email)}" placeholder="email@company.com" onchange="attendees[${a.id}].email=this.value;attendees[${a.id}].company=guessCompany(this.value)" /></div>
          </div>
          ${a.id > 0 ? '<button class="btn btn-g" style="font-size:10px;padding:3px 8px;margin-top:4px;" onclick="removeManual('+a.id+')">× Sil</button>' : ''}
        </div>`;
    } else {
      html += `
        <div class="att-row ${sel?'sel':''}" onclick="toggleAtt(${a.id})">
          <input type="checkbox" ${sel?'checked':''} onclick="event.stopPropagation();toggleAtt(${a.id})" />
          <div style="flex:1">
            <div class="att-name">${esc(a.name)}</div>
            <div class="att-email">${esc(a.email)}</div>
          </div>
          ${a.company ? '<span class="att-badge">'+esc(a.company)+'</span>' : ''}
        </div>`;
    }
  });

  // Add manual guest button
  html += `<button class="btn btn-g" style="width:100%;margin-top:8px;font-size:12px;" onclick="addManualGuest()">+ Əl ilə qonaq əlavə et</button>`;

  list.innerHTML = html;

  const cnt = hasManual ? attendees.length : selectedIds.size;
  document.getElementById('attTitle').textContent = `Attendee-ləri seç (${cnt})`;
  document.getElementById('btnToStep2').textContent = `Davam et — Detalları doldur (${cnt} nəfər)`;
}

function toggleAtt(id) {
  if (selectedIds.has(id)) selectedIds.delete(id); else selectedIds.add(id);
  renderAttendeeList();
}

function addManualGuest() {
  const newId = attendees.length;
  attendees.push({ id: newId, name: '', email: '', company: '', vehicle: '', type: 'manual' });
  selectedIds.add(newId);
  renderAttendeeList();
}

function removeManual(id) {
  attendees = attendees.filter(a => a.id !== id);
  selectedIds.delete(id);
  renderAttendeeList();
}

// ═══════════════════════════════════════════════════
// STEP 2: GUEST DETAILS
// ═══════════════════════════════════════════════════
function renderGuestDetails() {
  const container = document.getElementById('guestDetails');
  const active = getActiveGuests();
  let html = '';

  active.forEach((g, i) => {
    const opts = SUBSIDIARIES.map(s =>
      `<option value="${esc(s)}" ${g.company===s?'selected':''}>${esc(s)}</option>`
    ).join('');

    html += `
      <div class="gcard">
        <div class="gcard-num">${i+1}</div>
        <div class="gcard-name">${esc(g.name) || '(ad daxil edin)'}</div>
        <div class="row" style="display:flex;gap:7px;">
          <div class="fg" style="flex:2"><label>Müəssisə / Şirkət</label>
            <select onchange="updateGuestField(${g.id},'company',this.value)">
              <option value="">Seçin...</option>${opts}
            </select>
          </div>
          <div class="fg" style="flex:1"><label>Nəqliyyat (varsa)</label>
            <input value="${esc(g.vehicle)}" placeholder="99-XX-000" onchange="updateGuestField(${g.id},'vehicle',this.value)" />
          </div>
        </div>
      </div>`;
  });

  container.innerHTML = html;
}

function updateGuestField(id, field, val) {
  const a = attendees.find(x => x.id === id);
  if (a) a[field] = val;
}

function getActiveGuests() {
  return attendees.filter(a => selectedIds.has(a.id) || a.type === 'manual');
}

// ═══════════════════════════════════════════════════
// STEP 3: PREVIEW
// ═══════════════════════════════════════════════════
function renderPreview() {
  const guests = getActiveGuests();
  const meta = getFormMeta();

  // Forma 1 preview
  let fHtml = `
    <div style="text-align:center;margin-bottom:8px;">
      <div style="font-weight:700;font-size:12px;">"SOCAR Tower"-ə buraxılış üçün</div>
      <div style="font-weight:700;letter-spacing:3px;">S İ F A R İ Ş</div>
    </div>
    <table><tbody>
      <tr class="info-row"><td>Bölmə</td><td>${esc(meta.department)}</td></tr>
      <tr class="info-row"><td>Məqsəd</td><td>${esc(meta.purpose)}</td></tr>
      <tr class="info-row"><td>Yer</td><td>${esc(meta.location)}</td></tr>
      <tr class="info-row"><td>Müddət</td><td>${esc(meta.period)}</td></tr>
    </tbody></table>
    <table style="margin-top:8px;">
      <thead><tr><th>№</th><th>Ad Soyad</th><th>Müəssisə</th><th>Nəqliyyat</th></tr></thead>
      <tbody>`;
  guests.forEach((g,i) => {
    fHtml += `<tr><td>${i+1}</td><td>${esc(g.name)}</td><td>${esc(g.company)}</td><td>${esc(g.vehicle)||'—'}</td></tr>`;
  });
  fHtml += `</tbody></table>`;
  document.getElementById('previewForma').innerHTML = fHtml;

  // Email preview
  const recipient = document.getElementById('fRecipient').value;
  document.getElementById('emailMeta').innerHTML =
    `<b>To:</b> ${esc(recipient)}<br>` +
    `<b>Subject:</b> Buraxılış sifarişi — ${esc(meetingData.subject)} (${esc(meta.period)})<br>` +
    `<b>Attach:</b> 📎 forma1_buraxilis.docx`;
  document.getElementById('emailBody').textContent = buildEmailText(guests, meta);
}

function getFormMeta() {
  return {
    purpose: document.getElementById('fPurpose').value,
    location: document.getElementById('fLocation').value,
    period: document.getElementById('fPeriod').value,
    department: document.getElementById('fDept').value,
    contact: document.getElementById('fContact').value,
    ext: document.getElementById('fExt').value,
    approverName: document.getElementById('fApprName').value,
    approverTitle: document.getElementById('fApprTitle').value,
  };
}

function buildEmailText(guests, meta) {
  let t = `Hörmətli həmkarlar,\n\nQoşmadakı həmkarların Baş Ofisə buraxılışı ilə bağlı dəstəyinizi xahiş edirik.\n\n`;
  t += `Hörmətlə,\n${meta.contact}`;
  return t;
}

function buildEmailHtml(guests, meta) {
  let h = `<div style="font-family:Segoe UI,sans-serif;font-size:13px;color:#323130;">`;
  h += `<p>Hörmətli həmkarlar,</p>`;
  h += `<p>Qoşmadakı həmkarların Baş Ofisə buraxılışı ilə bağlı dəstəyinizi xahiş edirik.</p>`;
  h += `<p>Hörmətlə,<br/><strong>${esc(meta.contact)}</strong></p>`;
  h += `</div>`;
  return h;
}

// ═══════════════════════════════════════════════════
// DOCX GENERATION (browser-side)
// ═══════════════════════════════════════════════════
async function generateForma1Docx(guests, meta) {
  const {
    Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell,
    AlignmentType, BorderStyle, WidthType, VerticalAlign
  } = docx;

  const thin = { style: BorderStyle.SINGLE, size: 1, color: "000000" };
  const brd = { top:thin, bottom:thin, left:thin, right:thin };
  const cm = { top:40, bottom:40, left:80, right:80 };
  const pw = 11906, ml = 1134, mr = 850;
  const cw = pw - ml - mr;
  const ilw = 3200, ivw = cw - ilw;
  const cNo=600, cName=3400, cComp=3400, cVeh=cw-cNo-cName-cComp;

  function infoRow(label, value) {
    return new TableRow({ children: [
      new TableCell({
        width:{size:ilw,type:WidthType.DXA}, borders:brd, margins:cm, verticalAlign:VerticalAlign.CENTER,
        children: label.split('\n').map(l => new Paragraph({children:[new TextRun({text:l,bold:true,size:22,font:'Times New Roman'})]}))
      }),
      new TableCell({
        width:{size:ivw,type:WidthType.DXA}, borders:brd, margins:cm, verticalAlign:VerticalAlign.CENTER,
        children: [new Paragraph({children:[new TextRun({text:value,italics:true,size:22,font:'Times New Roman'})]})]
      })
    ]});
  }

  function hdrCell(text, w) {
    return new TableCell({
      width:{size:w,type:WidthType.DXA}, borders:brd, margins:cm, verticalAlign:VerticalAlign.CENTER,
      children: text.split('\n').map(l => new Paragraph({alignment:AlignmentType.CENTER, children:[new TextRun({text:l,bold:true,size:20,font:'Times New Roman'})]}))
    });
  }

  function cell(text, w, bold, align) {
    return new TableCell({
      width:{size:w,type:WidthType.DXA}, borders:brd, margins:cm, verticalAlign:VerticalAlign.CENTER,
      children: [new Paragraph({alignment:align||AlignmentType.LEFT, children:[new TextRun({text,bold:!!bold,italics:!bold&&text!=='',size:20,font:'Times New Roman'})]})]
    });
  }

  const today = new Date();
  const months = ['yanvar','fevral','mart','aprel','may','iyun','iyul','avqust','sentyabr','oktyabr','noyabr','dekabr'];
  const dateStr = String(today.getDate()).padStart(2,'0') + ' ' + months[today.getMonth()] + ' ' + today.getFullYear();

  const noBrd = {top:{style:BorderStyle.NONE,size:0},bottom:{style:BorderStyle.NONE,size:0},left:{style:BorderStyle.NONE,size:0},right:{style:BorderStyle.NONE,size:0}};
  function plainCell(text,w,bold,italic){
    return new TableCell({
      width:{size:w,type:WidthType.DXA}, borders:noBrd, margins:cm,
      children:[new Paragraph({children:[new TextRun({text,bold:!!bold,italics:!!italic,size:20,font:'Times New Roman'})]})]
    });
  }

  const doc = new Document({
    styles: { default: { document: { run: { font:'Times New Roman', size:22 } } } },
    sections: [{
      properties: {
        page: { size:{width:pw,height:16838}, margin:{top:850,bottom:850,left:ml,right:mr} }
      },
      children: [
        new Paragraph({alignment:AlignmentType.LEFT, spacing:{after:100}, children:[new TextRun({text:'Forma 1',italics:true,size:20,font:'Times New Roman'})]}),
        new Paragraph({alignment:AlignmentType.CENTER, spacing:{before:100,after:40}, children:[new TextRun({text:'"SOCAR Tower"-ə buraxılış üçün',bold:true,size:24,font:'Times New Roman'})]}),
        new Paragraph({alignment:AlignmentType.CENTER, spacing:{after:100}, children:[new TextRun({text:'S İ F A R İ Ş',bold:true,size:24,font:'Times New Roman'})]}),
        new Paragraph({alignment:AlignmentType.RIGHT, spacing:{after:200}, children:[new TextRun({text:dateStr,italics:true,size:22,font:'Times New Roman'})]}),

        // Info table
        new Table({
          width:{size:cw,type:WidthType.DXA}, columnWidths:[ilw,ivw],
          rows: [
            infoRow('Sifarişi verən təşkilat, müəssisə, struktur bölmə:', meta.department + ', əlaqəli şəxs: ' + meta.contact + ' (' + meta.ext + ')'),
            infoRow('Dəvətin məqsədi:', meta.purpose),
            infoRow('Dəvət olunduğu yer:\n(mərtəbə)', meta.location),
            infoRow('Dəvət olunma tarixi və müddəti:\n(bir iş həftəsindən artıq olmamaqla)', meta.period),
          ]
        }),

        new Paragraph({spacing:{before:200,after:100}, children:[]}),

        // Guest table
        new Table({
          width:{size:cw,type:WidthType.DXA}, columnWidths:[cNo,cName,cComp,cVeh],
          rows: [
            new TableRow({children:[
              hdrCell('Sıra\n№',cNo), hdrCell('Soyadı, adı',cName),
              hdrCell('Təmsil etdiyi\nMüəssisə / Şirkət / Ölkə',cComp),
              hdrCell('Nəqliyyat vasitəsi\nMarkası / dövlət nömrə nişanı',cVeh),
            ]}),
            new TableRow({children:[
              cell('1',cNo,true,AlignmentType.CENTER), cell('2',cName,true,AlignmentType.CENTER),
              cell('3',cComp,true,AlignmentType.CENTER), cell('4',cVeh,true,AlignmentType.CENTER),
            ]}),
            ...guests.map((g,i) => new TableRow({children:[
              cell(''+(i+1),cNo,false,AlignmentType.CENTER), cell(g.name,cName),
              cell(g.company,cComp), cell(g.vehicle||'',cVeh),
            ]})),
            new TableRow({children:[
              cell('',cNo,false,AlignmentType.CENTER), cell('',cName), cell('',cComp), cell('',cVeh),
            ]}),
          ]
        }),

        new Paragraph({spacing:{before:300}, children:[]}),

        // Approver
        new Table({
          width:{size:cw,type:WidthType.DXA}, columnWidths:[2500,1500,3000,500,cw-2500-1500-3000-500],
          rows: [
            new TableRow({children:[
              plainCell('Sifariş verdi:',2500,true), plainCell('',1500),
              plainCell(meta.approverTitle,3000,false,true), plainCell('',500),
              plainCell(meta.approverName,cw-2500-1500-3000-500,false,true),
            ]}),
            new TableRow({children:[
              plainCell('',2500), plainCell('',1500),
              plainCell('(vəzifəsi)',3000,false,true), plainCell('',500),
              plainCell('(adı, soyadı)',cw-2500-1500-3000-500,false,true),
            ]}),
          ]
        }),

        new Paragraph({spacing:{before:300}, children:[]}),
        new Paragraph({spacing:{after:60}, children:[
          new TextRun({text:'Qeyd. ',bold:true,size:18,font:'Times New Roman'}),
          new TextRun({text:'1.Sifariş təsdiq üçün buraxılışa icazə vermə səlahiyyətinə malik olan vəzifəli şəxsə, icra üçün isə "socar.reception" ünvanına göndərilməlidir.',size:18,font:'Times New Roman'}),
        ]}),
        new Paragraph({children:[
          new TextRun({text:'2. 4-cü sütun qonağın "SOCAR-Tower"-in ərazisinə avtomobillə daxil olacağı təqdirdə doldurulmalıdır.',size:18,font:'Times New Roman'}),
        ]}),
      ]
    }]
  });

  const blob = await Packer.toBlob(doc);
  return blob;
}

// ═══════════════════════════════════════════════════
// SEND
// ═══════════════════════════════════════════════════
async function sendAll() {
  const btn = document.getElementById('btnSend');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Hazırlanır...';

  try {
    const guests = getActiveGuests();
    const meta = getFormMeta();
    const recipient = document.getElementById('fRecipient').value;

    // Generate DOCX
    const blob = await generateForma1Docx(guests, meta);

    // Convert to base64 for Office.js attachment
    const reader = new FileReader();
    reader.onloadend = function() {
      const base64 = reader.result.split(',')[1];

      try {
        // Try Office.js: create new email with attachment
        Office.context.mailbox.displayNewMessageFormAsync({
          toRecipients: [recipient],
          subject: 'Buraxılış sifarişi — ' + meetingData.subject + ' (' + meta.period + ')',
          htmlBody: buildEmailHtml(guests, meta),
          attachments: [{
            type: Office.MailboxEnums.AttachmentType.File,
            name: 'forma1_buraxilis.docx',
            url: 'data:application/vnd.openxmlformats-officedocument.wordprocessingml.document;base64,' + base64,
            isInline: false
          }]
        }, function(result) {
          if (result.status === Office.AsyncResultStatus.Failed) {
            // Fallback: save file locally and open mailto
            fallbackSend(blob, recipient, meta);
          }
          showDone(guests.length, recipient);
        });
      } catch(e) {
        // Outside Outlook: save file and show success
        saveAs(blob, 'forma1_buraxilis.docx');
        showDone(guests.length, recipient);
      }
    };
    reader.readAsDataURL(blob);

  } catch(err) {
    btn.disabled = false;
    btn.innerHTML = '📧 Göndər + 📎 Forma 1';
    showStatus('err', '⚠ Xəta: ' + err.message);
  }
}

function fallbackSend(blob, recipient, meta) {
  // Save the docx file locally
  saveAs(blob, 'forma1_buraxilis.docx');
  // Open mailto
  const subject = encodeURIComponent('Buraxılış sifarişi — ' + meetingData.subject + ' (' + meta.period + ')');
  const body = encodeURIComponent('Hörmətli həmkarlar,\n\nQoşmadakı həmkarların Baş Ofisə buraxılışı ilə bağlı dəstəyinizi xahiş edirik.\n\nHörmətlə,\n' + meta.contact);
  window.open('mailto:' + recipient + '?subject=' + subject + '&body=' + body);
}

function showDone(count, recipient) {
  document.getElementById('doneMsg').innerHTML =
    'Forma 1 (' + count + ' nəfər) Word formatında<br><b>' + esc(recipient) + '</b> ünvanına göndərildi.';
  showStep(4);
}

function showStatus(type, msg) {
  const bar = document.getElementById('statusBar');
  bar.className = 'status ' + (type === 'err' ? 'err' : 'ok');
  bar.textContent = msg;
  bar.classList.remove('hidden');
}

function resetAll() {
  selectedIds = new Set(attendees.map(a => a.id));
  showStep(0);
}

function esc(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
</body>
</html>
